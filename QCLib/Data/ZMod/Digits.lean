import Mathlib

/-!

# Representation of elements of `ZMod (d ^ n)` by digits

This WIP file builds a theory of "digits" for elements of `ℤ_{d^n}`.

The module is motivated by the observation that the structure of the quantum
Fourier transform circuit reflects a certain recursive formula for multiplying
numbers in `ℤ_{d^n}` in terms of their digits.

## Main definitions

* `digitsEquiv : ZMod (d ^ n) ≃ (Fin n → Fin d)` represents `ZMod d ^ n` by digits,
in little-endian order

* `digitsBEEquiv : ZMod (d ^ n) ≃ (Fin n → Fin d)` represents `ZMod d ^ n` by digits,
in big-endian order


## Main results

* `ofDigits_mul_ofDigitsBE_rec` a recursive formula for multiplying numbers in
`ZMod d ^ n`, where one is given in BE and one in LE order.

* `idftRec` a recursive formula for the inverse DFT over `ℤ_{d^n}`

## To do

Clean up this mess.

-/

section lemmas

@[simp]
theorem ZMod.val_sum_of_lt {ι : Type*} {n : ℕ} (f : ι → ZMod n) (s : Finset ι)
    (h : ∑ i ∈ s, (f i).val < n) : (∑ i ∈ s, f i).val = ∑ i ∈ s, (f i).val := by
  have : NeZero n := by constructor; rintro rfl; simp at h
  induction s using Finset.cons_induction with
  | empty => simp
  | cons a s ha hi => simp_all [val_add_of_lt, hi (by grind)]

-- Is this an idiomatic statement?
@[to_additive]
theorem Finset.prod_univ_split {M : Type*} [CommMonoid M] {n : ℕ} (j : Fin n) (f : Fin n → M) :
    (∏ i, f i) = (∏ i ≤ j, f i) * ∏ i > j, f i := by
  have hu : Finset.univ = (Finset.Iic j) ∪ (Finset.Ioi j) := by grind
  have hd : Disjoint (Finset.Iic j) (Finset.Ioi j) := by grind [Finset.disjoint_left]
  rw [hu, Finset.prod_union hd]

end lemmas

namespace Nat

-- not used
theorem ofDigits_expand {p : ℕ} (L : List ℕ) :
    ofDigits p L = ∑ i : Fin L.length, L[i] * p ^ (i : ℕ) := by
  induction L with
  | nil => simp
  | cons h t hi =>
    simp [Fin.sum_univ_succ, ofDigits_cons, hi, Finset.mul_sum]
    ring_nf

attribute [simp] Nat.pos_of_neZero
attribute [simp] Nat.AtLeastTwo.one_lt

end Nat

namespace Fin

abbrev digitsEquiv {n d : ℕ} : Fin (d ^ n) ≃ (Fin n → Fin d) := finFunctionFinEquiv.symm

-- Re-uses a proof from `finFunctionFinEquiv`.
@[simp]
theorem ofDigits_lt {m n : ℕ} (f : Fin n → Fin m) :
    ∑ i, f i * m ^ (i : ℕ) < m ^ n :=
  (digitsEquiv.symm f).isLt

-- `NeZero m` not necessary
@[simp]
theorem ofDigits_lt' {m n k : ℕ} [NeZero m] (hkn : k ≤ n) (f : Fin k → Fin m) :
    ∑ i, f i * m ^ (i : ℕ) < m ^ n := by
  refine lt_of_lt_of_le (ofDigits_lt f) ?_
  exact Nat.pow_le_pow_right (by simp) hkn

-- That's different from `_root_.finFunctionFinEquiv` (which is also a dupe of
-- the one generated by `simps`. TBD: PR to deprecate)
theorem finFunctionFinEquiv_apply {m n : ℕ} (f : Fin n → Fin m) :
    digitsEquiv.symm f = ⟨∑ i, f i * m ^ (i : ℕ), ofDigits_lt f⟩ := by
  ext; simp

theorem val_self_expansion {n d : ℕ} (x : Fin (d ^ n)) :
    (x : ℕ) = ∑ i, (finFunctionFinEquiv.symm x i) * (d ^ (i : ℕ) : ℕ) := by
  conv_lhs => rw [show x = finFunctionFinEquiv (finFunctionFinEquiv.symm x) by simp]
  simp only [finFunctionFinEquiv_apply_val]

end Fin

namespace ZMod

section castHom

@[simp]
theorem pow_div_pow {d e n : ℕ} : d ^ n ∣ d ^ (n + e) := by
  simp [pow_add]

@[simp]
theorem pow_div_pow_succ {d n : ℕ} : d ^ n ∣ d ^ n.succ := pow_div_pow (e:=1)

@[simps!]
def castHomPow (d n e : ℕ) : ZMod (d ^ (n + e)) →+* ZMod (d ^ n) :=
  castHom pow_div_pow (ZMod (d ^ n))

@[simps!]
def predHom (d n : ℕ) : ZMod (d ^ (n + 1)) →+* ZMod (d ^ n) :=
  castHom pow_div_pow_succ (ZMod (d ^ n))

variable {d n e : ℕ}

@[simp]
theorem predHom_ker' : predHom d n (d ^ n) = 0 := by
  simp [natCast_pow_eq_zero_of_le]

theorem castHomePow_ker (x : Fin e → (ZMod (d ^ (n + e)))) :
    castHomPow d n e (∑ i, x i * ↑d ^ (n + i)) = 0 := by
  simp [natCast_pow_eq_zero_of_le]

end castHom

-- Some pieces of missing API for `ZMod.finEquiv`
section finEquiv

@[simp]
theorem finEquiv_val {n : ℕ} [hnz : NeZero n] (x : Fin n) : (finEquiv n x).val = (x : ℕ) := by
  cases n
  · cases NeZero.ne 0 rfl
  · rfl

@[simp]
theorem finEquiv_symm_val {n : ℕ} [NeZero n] (x : ZMod n) : ((finEquiv n).symm x).val = x.val := by
  cases n
  · cases NeZero.ne 0 rfl
  · rfl

@[simp]
theorem finEquiv_symm_cast_val {n : ℕ} [NeZero n] (x : Fin n) :
    (finEquiv n).symm (x.val : ZMod n) = x := by
  ext
  simp only [finEquiv_symm_val, val_natCast_of_lt x.isLt]

end finEquiv

-- namespace to allow for dot notation
def _root_.Function.ofDigits {n d : ℕ} (f : Fin n → Fin d) : (ZMod (d ^ n)) :=
  ((Fin.digitsEquiv.symm f) : ZMod (d ^ n))

theorem ofDigits_def {n d : ℕ} (f : Fin n → Fin d) :
    f.ofDigits = ((Fin.digitsEquiv.symm f) : ZMod (d ^ n)) := rfl

def digits {n d : ℕ} [NeZero d] (x : ZMod (d ^ n)) : Fin n → Fin d :=
  fun i ↦ finFunctionFinEquiv.symm ((ZMod.finEquiv _).symm x) i

theorem digits_def {n d : ℕ} [NeZero d] (x : ZMod (d ^ n)) :
    x.digits = Fin.digitsEquiv ((finEquiv (d ^ n)).symm x) := rfl

theorem digits_ofDigits {n d : ℕ} [NeZero d] (f : Fin n → Fin d) :
    digits f.ofDigits = f := by
  ext i
  simp only [digits_def, ofDigits_def, finEquiv_symm_cast_val, Equiv.symm_symm,
    Equiv.symm_apply_apply]

theorem ofDigits_digits {n d : ℕ} [NeZero d] (x : ZMod (d ^ n)) :
    x.digits.ofDigits = x := by
  simp [digits_def, ofDigits_def]

-- TBD: Make `apply_val` non-simp?
@[simps!?]
def digitsEquiv {n d : ℕ} [NeZero d] : (ZMod (d ^ n)) ≃ (Fin n → Fin d) where
  toFun := digits
  invFun := Function.ofDigits
  left_inv := ofDigits_digits
  right_inv := digits_ofDigits
-- or use this as standard lemmas?
theorem digitsEquiv_apply {n d : ℕ} [NeZero d] (x : ZMod (d ^ n)) : digitsEquiv x = x.digits := rfl


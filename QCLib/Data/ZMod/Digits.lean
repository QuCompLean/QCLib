section trivialities

-- Easier?
@[simp]
theorem _root_.Nat.le_pow_pow_add {n d e : ℕ} [NeZero d] : d ^ n ≤ d ^ (n + e) :=
  Nat.pow_le_pow_right (gt_iff_lt.mpr (by simp)) (by simp)

@[simp]
theorem _root_.Fin.le_pow_pow_self {n d : ℕ} [NeZero d] (i : Fin n) : d ^ (i : ℕ) ≤ d ^ n :=
  Nat.pow_le_pow_right (by simp) (by simp)

@[simp]
theorem _root_.Fin.lt_pow_pow_self {n m d : ℕ} [d.AtLeastTwo] (hmn : m ≤ n) (i : Fin m) :
  d ^ (i : ℕ) < d ^ n :=
  Nat.pow_lt_pow_right (by simp) (by grind)

theorem val_cast_succ_eq_val {n d : ℕ} [NeZero d] (a : ZMod (d ^ n)) :
    (a.cast : ZMod (d ^ (n + 1))).val = a.val :=
  val_cast_eq_val_of_lt <| lt_of_lt_of_le a.val_lt (by simp)

theorem cast_succ_cast {n d : ℕ} [NeZero d] (a : ZMod (d ^ n)) :
    (a.cast : ZMod (d ^ (n + 1))).cast = a :=
  cast_cast_zmod_of_le (by simp) a

/-- Analogue of `ZMod.val_cast_eq_va_of_lt` starting from a `Fin` -/
theorem _root_.Fin.val_zModCast_of_le {n m : ℕ} [NeZero n] (h : n ≤ m) (a : Fin n) :
    (a.val : ZMod m).val = a := by
  rw [val_natCast]
  exact Nat.mod_eq_of_lt <| lt_of_lt_of_le a.is_lt h

@[simp]
theorem _root_.Fin.val_zModCast_of_pow {n d : ℕ} [NeZero d] [hnz : NeZero n] (a : Fin d) :
    (a.val : ZMod (d ^ n)).val = a :=
  a.val_zModCast_of_le (Nat.le_self_pow hnz.out d)

theorem _root_.Nat.val_zModCast_base_of_pow {n d : ℕ} [d.AtLeastTwo] [NeZero n] :
    (d : ZMod (d ^ (n + 1))).val = d := by
  apply val_natCast_of_lt
  apply lt_self_pow₀ <;> simp

example {n b e : ℕ} : (b ^ e).cast = (b.cast : ZMod n) ^ e := Nat.cast_pow b e

@[simp]
theorem val_cast_pow_eq_val_pow {n m d : ℕ} [d.AtLeastTwo] (hmn : m ≤ n) (i : Fin m) :
    (d ^ (i : ℕ) : ZMod (d ^ n)).val = d ^ (i : ℕ) := by
  rw [← Nat.cast_pow]
  exact val_natCast_of_lt (i.lt_pow_pow_self hmn)

-- name?
@[simp]
theorem lt_digit_mul {n m d : ℕ} [NeZero d] (hmn : m ≤ n) (i : Fin m) (x : Fin d) :
    x * d ^ (i : ℕ) < d ^ n := by
  refine lt_of_lt_of_le (b := d * d ^ (i : ℕ)) ?_ ?_
  · simp
  · rw [mul_comm, ← Nat.pow_succ]
    have : i < n := by grind
    simp [d.pow_le_pow_right, this]

@[simp]
theorem val_digit_mul {n m d : ℕ} [d.AtLeastTwo] [NeZero n] (hmn : m ≤ n) (i : Fin m) (x : Fin d) :
  (x * (d ^ (i : ℕ) : ZMod (d ^ n))).val = x.val * (d ^ (i : ℕ)) := by
    rw [val_mul_of_lt] <;> simp [hmn, x.val_zModCast_of_pow]

end trivialities

@[simp]
theorem val_expansion {n m d : ℕ} [d.AtLeastTwo] [NeZero n] (hmn : m ≤ n) (f : Fin m → Fin d) :
    (∑ i, f i * (d ^ (i : ℕ) : ZMod (d ^ n))).val = ∑ i, (f i).val * d ^ (i : ℕ) := by
  simp_rw [← val_digit_mul hmn]
  apply val_sum_of_lt
  simp [hmn, val_digit_mul]

theorem ofDigits_expansion {n d : ℕ} [NeZero d] (f : Fin n → Fin d) :
    f.ofDigits = ∑ i, f i * (d ^ (i : ℕ) : ZMod (d ^ n)) := by
  simp [ofDigits_def]

theorem digits_expansion {n d : ℕ} [NeZero d] (f : Fin n → Fin d) :
    (∑ i, (f i * (d ^ (i : ℕ)) : ZMod (d ^ n))).digits = f := by
  have := (congrArg digitsEquiv (ofDigits_expansion f)).symm
  rw [← digitsEquiv_apply, ← digitsEquiv_symm_apply] at *
  simp only [this, Equiv.apply_symm_apply]

theorem self_expansion {n d : ℕ} [NeZero d] (x : ZMod (d ^ n)) :
    x = ∑ i, x.digits i * (d ^ (i : ℕ) : ZMod (d ^ n)) := by
  conv_lhs => rw [show x = digitsEquiv.symm (digitsEquiv x) by simp]
  rw [digitsEquiv_symm_apply]
  simp only [ofDigits_expansion]
  rw [← digitsEquiv_apply]

-- Better than the simps theorem `_apply_val`.
theorem digitsEquiv_apply' {n d : ℕ} [hnz : NeZero d] (x : ZMod (d ^ n)) (i : Fin n) :
    x.digits i = ⟨(x.val / d ^ (i : ℕ)) % d, Nat.mod_lt _ ((Nat.pos_of_neZero d))⟩ := by
  ext
  simp [← digitsEquiv_apply, digitsEquiv_apply_val]

/-- Casting from `d ^ (n + 1)` to `d ^ n` removes the most significant digit -/
theorem digits_predHom {n d : ℕ} [NeZero d] (x : ZMod (d ^ (n + 1))) :
    (predHom d n x).digits = Fin.init x.digits := by
  conv_lhs => rw [self_expansion x]
  simp only [map_sum, map_mul]
  simp only [Fin.sum_univ_castSucc, Fin.val_last, predHom_ker']
  simp [-digitsEquiv_apply_val, digits_expansion, Fin.init_def]

theorem cast_pred {n d : ℕ} [NeZero d] (x : ZMod (d ^ (n + 1))) :
    (x.cast : ZMod (d ^ n))
      = ∑ i : Fin n, (x.digits i.castSucc) * (d ^ (i : ℕ) : ZMod (d ^ n)) := by
  conv_lhs => rw [self_expansion x.cast]
  rw [← predHom_apply, digits_predHom]
  simp [Fin.init_def]

/-- Casting down, then casting up clears the most significant digit -/
theorem cast_cast_pred {n d : ℕ} [NeZero n] [d.AtLeastTwo] (x : ZMod (d ^ (n + 1))) :
    (x.cast : ZMod (d ^ n)).cast
      = ∑ i : Fin n, (x.digits i.castSucc) * (d ^ (i : ℕ) : ZMod (d ^ (n + 1))) := by
  rw [cast_pred]
  apply val_injective
  rw [val_cast_succ_eq_val]
  rw [val_expansion (by simp), val_expansion (by simp)]

theorem mul_expansion {d n : ℕ} [NeZero n] [d.AtLeastTwo] (x : ZMod (d ^ (n + 1))) :
    (x * (d : ZMod (d ^ (n + 1)))) =
       ∑ i : Fin n, (x.digits i.castSucc) * (d ^ ((i : ℕ) + 1) : ZMod (d ^ (n + 1))) := by
  conv_lhs => rw [self_expansion x]
  rw [Finset.sum_mul]
  simp_rw [mul_assoc, ← pow_succ]
  simp only [Fin.sum_univ_castSucc, Fin.val_last]
  simp [-digitsEquiv_apply_val, natCast_pow_eq_zero_of_le]

theorem mul_eq_cast_cast_pred_mul {d n : ℕ} [NeZero n] [d.AtLeastTwo] (x : ZMod (d ^ (n + 1))) :
    (x * (d : ZMod (d ^ (n + 1)))) = (x.cast : ZMod (d ^ n)).cast * d := by
  rw [mul_expansion, cast_cast_pred, Finset.sum_mul]
  grind


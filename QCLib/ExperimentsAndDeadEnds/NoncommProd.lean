/- These ended up not being required -/
section NotUsed

variable {M : Type*} [Monoid M]

open Submonoid

open scoped Function -- required for scoped `on` notation

--- TBD: Is there an analogous `prod` statement? Get names aligned.
@[simp, norm_cast]
theorem _root_.Submonoid.coe_noncommProd (N : Submonoid M) (s : Finset ι) (f : ι → N)
    (comm : (s : Set ι).Pairwise (Commute on f)) :
    (↑(s.noncommProd f comm) : M) = s.noncommProd (fun i ↦ ↑(f i))
      (comm.imp (fun _ _ h ↦ coe_commute_iff.mpr h)) :=
  s.map_noncommProd f comm N.subtype

namespace Finset

/-- Analogue of `Finset.prod_attach`. -/
theorem noncommProd_attach {ι : Type*} (S : Finset ι) (f : ι → M)
    (comm : (S : Set ι).Pairwise (Commute on f)) :
    (S.noncommProd f comm) = S.attach.noncommProd (fun x ↦ f x)
    ((fun ⟨_, ha⟩ _ ⟨_, hb⟩ _ hne ↦ comm ha hb (fun h ↦ hne (Subtype.ext h)))) := by
  simp only [noncommProd, attach_val]
  congr 1
  rw [← Multiset.attach_map_val']
  rfl -- TBD

end NotUsed.Finset
